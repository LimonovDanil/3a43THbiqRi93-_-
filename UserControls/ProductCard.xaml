<UserControl x:Class="CoffeeShop.UserControls.ProductCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CoffeeShop.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="250" d:DesignWidth="180">
    <Grid>
        <Border >
            <StackPanel>
                <Border BorderThickness="1">
                    <Image Source="{Binding FullImagePath}" Margin="5"/>
                </Border>
                <StackPanel>
                    <TextBlock Text="{Binding Name}"/>
                    <TextBlock Text="{Binding Categories.Name}"/>
                    <TextBlock Text="{Binding Price}"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
