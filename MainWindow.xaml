<Window x:Class="CoffeeShop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CoffeeShop"
        mc:Ignorable="d"
        Title="Coffee Shop" Height="600" Width="900"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        
        <Rectangle Name="headerRect" Fill="#8B4513" Grid.Row="0" Visibility="Collapsed"/>
        <StackPanel Name="headerPanel" Orientation="Horizontal" Grid.Row="0" Margin="10" Visibility="Collapsed">
            <Image Source="/Images/Coffee.png" Width="50" Height="50" Margin="5"/>
            <TextBlock Text="Coffee Shop" FontSize="24" FontWeight="Bold" 
                       Foreground="White" VerticalAlignment="Center" Margin="10,0"/>
            <TextBlock Name="txtUserInfo" FontSize="14" Foreground="White" 
                       VerticalAlignment="Center" Margin="20,0,0,0"/>
        </StackPanel>

      
        <StackPanel Name="menuPanel" Orientation="Horizontal" Grid.Row="0" HorizontalAlignment="Right" 
                    VerticalAlignment="Center" Margin="0,0,20,0" Visibility="Collapsed">
            <Button Name="btnProducts" Content="Товары" Width="80" Height="35" 
                    Margin="5" Background="White" Foreground="#8B4513"
                    Click="btnProducts_Click"/>
            <Button Name="btnLogout" Content="Выход" Width="80" Height="35" 
                    Margin="5" Background="Red" Foreground="White"
                    Click="btnLogout_Click"/>
        </StackPanel>

       
        <Frame Name="MainFrame" Grid.RowSpan="2" NavigationUIVisibility="Hidden"/>
    </Grid>
</Window>
