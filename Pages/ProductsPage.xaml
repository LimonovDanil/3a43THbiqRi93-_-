<Page x:Class="CoffeeShop.Pages.ProductsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:CoffeeShop.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Товары" Background="#F5F5F5">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Категория:" VerticalAlignment="Center" Margin="5"/>
            <ComboBox Name="cmbCategory" Width="150" Height="30" Margin="5"
                      SelectionChanged="cmbCategory_SelectionChanged"/>
            <TextBlock Text="Поиск:" VerticalAlignment="Center" Margin="5"/>
            <TextBox Name="txtSearch" Width="200" Height="30" Margin="5"
                     TextChanged="txtSearch_TextChanged"/>
            <Button Name="btnClear" Content="Очистить" Width="80" Height="30" 
                    Margin="5" Click="btnClear_Click"/>
        </StackPanel>
        <Button Name="btnAdd" Content="Добавить товар" Width="120" Height="35" 
                Grid.Row="1" Margin="0,0,0,10" HorizontalAlignment="Left"
                Background="#8B4513" Foreground="White" Click="btnAdd_Click"
                Visibility="Collapsed"/>
        <DataGrid Name="dgProducts" Grid.Row="2" AutoGenerateColumns="False" 
                  IsReadOnly="True" SelectionMode="Single"
                  CanUserAddRows="False" RowHeight="40">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="200"/>
                <DataGridTextColumn Header="Цена" Binding="{Binding Price}" Width="100"/>
                <DataGridTextColumn Header="Категория" Binding="{Binding Categories.Name}" Width="120"/>
                <DataGridTemplateColumn Header="Действия" Width="200">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Content="Купить" Width="70" Margin="2" 
                                        Background="Green" Foreground="White"
                                        Click="BuyProduct_Click" Tag="{Binding}"
                                   />
                                <Button Content="Редакт." Width="70" Margin="2" 
                                        Background="Orange" Foreground="White"
                                        Click="EditProduct_Click" Tag="{Binding}"
                                       />
                                <Button Content="Удалить" Width="70" Margin="2" 
                                        Background="Red" Foreground="White"
                                        Click="DeleteProduct_Click" Tag="{Binding}"
                                        />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
