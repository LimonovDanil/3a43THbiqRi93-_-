<Page x:Class="CoffeeShop.Pages.RegisterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:CoffeeShop.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Регистрация"
      Background="#F5F5F5">
    <Grid>
        <Grid Width="350" Height="400" VerticalAlignment="Center" HorizontalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Text="Регистрация нового пользователя" 
                       FontSize="16" FontWeight="Bold" 
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,20" 
                       Grid.Row="0"
                       Foreground="#8B4513"/>
            <TextBlock Text="Логин:" Grid.Row="1" Margin="0,5" FontSize="12"/>
            <TextBox Name="txtLogin" Grid.Row="2" Height="35" Margin="0,0,0,10"
                     FontSize="14" Padding="5"/>
            <TextBlock Text="Пароль:" Grid.Row="3" Margin="0,5" FontSize="12"/>
            <PasswordBox Name="txtPassword" Grid.Row="4" Height="35" Margin="0,0,0,10"
                         FontSize="14"/>
            <TextBlock Text="Подтверждение пароля:" Grid.Row="5" Margin="0,5" FontSize="12"/>
            <PasswordBox Name="txtConfirmPassword" Grid.Row="6" Height="35" Margin="0,0,0,10"
                         FontSize="14"/>
            <TextBlock Text="Полное имя:" Grid.Row="7" Margin="0,5" FontSize="12"/>
            <TextBox Name="txtFullName" Grid.Row="8" Height="35" Margin="0,0,0,10"
                     FontSize="14" Padding="5"/>
            <Button Name="btnRegister" Content="Зарегистрироваться" Grid.Row="9" Height="40" 
                    Background="#8B4513" Foreground="White" FontSize="14" 
                    FontWeight="Bold" Cursor="Hand" Click="btnRegister_Click"
                    Margin="0,10,0,5"/>
            <Button Name="btnBack" Content="Назад к входу" Grid.Row="10" Height="35"
                    Background="Transparent" Foreground="#8B4513" 
                    FontSize="12" Cursor="Hand" BorderThickness="0"
                    Click="btnBack_Click"/>
            <TextBlock Name="txtError" Grid.Row="11" Foreground="Red" 
                       HorizontalAlignment="Center" Margin="0,10,0,0"
                       FontSize="11"/>
        </Grid>
    </Grid>
</Page>