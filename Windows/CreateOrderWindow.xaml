<Window x:Class="CoffeeShop.Windows.CreateOrderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CoffeeShop.Windows"
        mc:Ignorable="d"
               Title="Оформление заказа" Height="400" Width="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Background="#F5F5F5">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Text="☕ Оформление заказа" 
                       FontSize="18" FontWeight="Bold" 
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,20" 
                       Grid.Row="0"
                       Foreground="#8B4513"/>
            <Border Grid.Row="1" Background="#FFF4E6" CornerRadius="5" 
                    Padding="10" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="Выбранный товар:" FontSize="12" 
                               Foreground="#8B4513" FontWeight="Bold"/>
                    <TextBlock Name="txtProductName" FontSize="16" 
                               FontWeight="Bold" Margin="0,5,0,0"
                               Foreground="#8B4513"/>
                    <TextBlock Name="txtProductPrice" FontSize="14" 
                               Margin="0,5,0,0"/>
                </StackPanel>
            </Border>
            <TextBlock Text="Количество:" Grid.Row="2" Margin="0,5" 
                       FontSize="12" FontWeight="Bold"/>
            <StackPanel Orientation="Horizontal" Grid.Row="3" Margin="0,0,0,15">
                <Button Content="−" Width="35" Height="35" 
                        Background="#8B4513" Foreground="White"
                        FontSize="16" FontWeight="Bold"
                        Click="DecreaseQuantity_Click"
                        Cursor="Hand"/>
                <TextBox Name="txtQuantity" Text="1" Width="80" Height="35" 
                         TextAlignment="Center" FontSize="14"
                         Margin="10,0" TextChanged="txtQuantity_TextChanged"
                         PreviewTextInput="txtQuantity_PreviewTextInput"/>
                <Button Content="+" Width="35" Height="35" 
                        Background="#8B4513" Foreground="White"
                        FontSize="16" FontWeight="Bold"
                        Click="IncreaseQuantity_Click"
                        Cursor="Hand"/>
            </StackPanel>
            <Border Grid.Row="4" Background="#E8F5E9" CornerRadius="5" 
                    Padding="10" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="Сумма заказа:" FontSize="12" 
                               Foreground="Green" FontWeight="Bold"/>
                    <TextBlock Name="txtTotal" FontSize="20" 
                               FontWeight="Bold" Margin="0,5,0,0"
                               Foreground="Green"/>
                </StackPanel>
            </Border>
            <Expander Header="Дополнительная информация" Grid.Row="5" 
                      Margin="0,0,0,15" IsExpanded="False">
                <StackPanel Margin="10">
                    <TextBlock Text="Комментарий к заказу:" FontSize="12"/>
                    <TextBox Name="txtComment" Height="60" 
                             TextWrapping="Wrap" Margin="0,5,0,0"
                             AcceptsReturn="True"/>
                    <TextBlock Text="Пожелания:" FontSize="12" 
                               Margin="0,10,0,0"/>
                    <TextBox Name="txtWishes" Height="40" 
                             TextWrapping="Wrap" Margin="0,5,0,0"/>
                </StackPanel>
            </Expander>
            <StackPanel Orientation="Horizontal" Grid.Row="6" 
                        HorizontalAlignment="Center" Margin="0,10,0,0">
                <Button Name="btnOrder" Content="✅ Оформить заказ" 
                        Width="140" Height="40" 
                        Margin="5" Background="#4CAF50" 
                        Foreground="White" FontSize="14"
                        FontWeight="Bold" Cursor="Hand"
                        Click="btnOrder_Click"/>
                <Button Name="btnCancel" Content="❌ Отмена" 
                        Width="100" Height="40" 
                        Margin="5" Background="#9E9E9E" 
                        Foreground="White" FontSize="14"
                        FontWeight="Bold" Cursor="Hand"
                        Click="btnCancel_Click"/>
            </StackPanel>
            <TextBlock Grid.Row="7" Text="* Заказ будет привязан к вашему аккаунту" 
                       FontSize="10" Foreground="Gray" 
                       HorizontalAlignment="Center" Margin="0,10,0,0"/>
        </Grid>
    </Grid>
</Window>

