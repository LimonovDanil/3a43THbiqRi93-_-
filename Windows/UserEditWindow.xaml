<Window x:Class="CoffeeShop.Windows.UserEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CoffeeShop.Windows"
        mc:Ignorable="d"
       Title="Редактирование пользователя" Height="550" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Background="#F5F5F5">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="👤 Редактирование пользователя" 
                       FontSize="18" FontWeight="Bold" 
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,20" 
                       Grid.Row="0"
                       Foreground="#8B4513"/>


            <TextBlock Text="Логин:" Grid.Row="1" Margin="0,5" 
                       FontSize="12" FontWeight="Bold"/>
            <TextBox Name="txtLogin" Grid.Row="2" Height="35" Margin="0,0,0,15"
                     FontSize="14" Padding="5"
                     TextChanged="txtLogin_TextChanged"/>


            <TextBlock Text="Пароль:" Grid.Row="3" Margin="0,5" 
                       FontSize="12" FontWeight="Bold"/>
            <PasswordBox Name="txtPassword" Grid.Row="4" Height="35" Margin="0,0,0,15"
                         FontSize="14"
                         PasswordChanged="txtPassword_PasswordChanged"/>

            <TextBlock Text="Подтверждение пароля:" Grid.Row="5" Margin="0,5" 
                       FontSize="12" FontWeight="Bold"/>
            <PasswordBox Name="txtConfirmPassword" Grid.Row="6" Height="35" Margin="0,0,0,15"
                         FontSize="14"
                         PasswordChanged="txtConfirmPassword_PasswordChanged"/>

 
            <TextBlock Text="Полное имя:" Grid.Row="7" Margin="0,5" 
                       FontSize="12" FontWeight="Bold"/>
            <TextBox Name="txtFullName" Grid.Row="8" Height="35" Margin="0,0,0,15"
                     FontSize="14" Padding="5"
                     TextChanged="txtFullName_TextChanged"/>

            <!-- Роль -->
            <TextBlock Text="Роль:" Grid.Row="9" Margin="0,5" 
                       FontSize="12" FontWeight="Bold"/>
            <ComboBox Name="cmbRole" Grid.Row="10" Height="35" Margin="0,0,0,15"
                      DisplayMemberPath="Name" SelectedValuePath="Id"
                      FontSize="14"/>

   
            <Border Grid.Row="11" Background="#FFF4E6" CornerRadius="5" 
                    Padding="10" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="Информация:" FontSize="11" 
                               Foreground="#8B4513" FontWeight="Bold"/>
                    <TextBlock Name="txtInfo" FontSize="12" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

 
            <StackPanel Orientation="Horizontal" Grid.Row="12" 
                        HorizontalAlignment="Center" Margin="0,10,0,0">
                <Button Name="btnSave" Content="💾 Сохранить" 
                        Width="120" Height="40" 
                        Margin="5" Background="#4CAF50" 
                        Foreground="White" FontSize="14"
                        FontWeight="Bold" Cursor="Hand"
                        Click="btnSave_Click"/>
                <Button Name="btnCancel" Content="❌ Отмена" 
                        Width="100" Height="40" 
                        Margin="5" Background="#9E9E9E" 
                        Foreground="White" FontSize="14"
                        FontWeight="Bold" Cursor="Hand"
                        Click="btnCancel_Click"/>
            </StackPanel>

            <TextBlock Name="txtError" Grid.Row="13" Foreground="Red" 
                       HorizontalAlignment="Center" Margin="0,10,0,0"
                       FontSize="11"/>
        </Grid>
    </Grid>
</Window>
